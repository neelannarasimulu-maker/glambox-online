generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                 String               @id
  email              String               @unique
  passwordHash       String?              @map("password_hash")
  fullName           String               @map("full_name")
  phone              String?
  dateOfBirth        String?              @map("date_of_birth")
  address            String?
  city               String?
  country            String?
  bio                String?
  preferences        String?
  dislikes           String?
  medicalInfo        String?              @map("medical_info")
  hairPreferences    String?              @map("hair_preferences")
  nailPreferences    String?              @map("nail_preferences")
  foodPreferences    String?              @map("food_preferences")
  onboardingCompleted Boolean             @default(false) @map("onboarding_completed")
  authProvider       String               @default("email") @map("auth_provider")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  sessions           AuthSession[]
  loginEvents        AuthLoginEvent[]
  bookings           Booking[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model AuthSession {
  id        String   @id
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  provider  String
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_auth_sessions_user")
  @@index([tokenHash], map: "idx_auth_sessions_token")
  @@map("auth_sessions")
}

model AuthLoginEvent {
  id         String   @id
  userId     String   @map("user_id")
  provider   String
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @map("occurred_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt], map: "idx_auth_login_events_user_time")
  @@map("auth_login_events")
}

model Booking {
  id             String   @id
  userId         String   @map("user_id")
  popupKey       String   @map("popup_key")
  popupName      String   @map("popup_name")
  serviceId      String   @map("service_id")
  serviceTitle   String   @map("service_title")
  consultantId   String   @map("consultant_id")
  consultantName String   @map("consultant_name")
  bookingDate    String   @map("booking_date")
  bookingTime    String   @map("booking_time")
  status         String   @default("confirmed")
  notes          String?
  lastAction     String?  @map("last_action")
  actionReason   String?  @map("action_reason")
  source         String   @default("web")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, bookingDate, bookingTime], map: "idx_bookings_user_date")
  @@index([userId, status, bookingDate, bookingTime], map: "idx_bookings_user_status_date")
  @@map("bookings")
}

model PasswordResetToken {
  id        String   @id
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenHash, usedAt, expiresAt], map: "idx_password_reset_lookup")
  @@map("password_reset_tokens")
}

model ApiRateLimit {
  key             String   @id
  count           Int
  windowStartedAt DateTime @map("window_started_at")
  expiresAt       DateTime @map("expires_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([expiresAt], map: "idx_api_rate_limits_expires_at")
  @@map("api_rate_limits")
}
